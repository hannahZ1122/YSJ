.container {
  min-height: 100vh;
  background: transparent;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--spacing-page);
  box-sizing: border-box;
}

/* ── 页面背景图 ── */
.page-bg {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  opacity: 0.20;
  pointer-events: none;
}

/* ── 旋转动画 ── */
.animation-wrap {
  margin-bottom: 64rpx;
}

.spinner {
  display: flex;
  gap: 20rpx;
  align-items: center;
}

.dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: var(--color-primary);
  animation: bounce 1.2s infinite ease-in-out;
}

.dot2 { animation-delay: 0.2s; }
.dot3 { animation-delay: 0.4s; }

@keyframes bounce {
  0%, 80%, 100% {
    transform: scale(0.6);
    opacity: 0.4;
  }
  40% {
    transform: scale(1.2);
    opacity: 1;
  }
}

/* ── 文案 ── */
.text-wrap {
  text-align: center;
}

.loading-text {
  display: block;
  font-size: var(--font-xl);
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 16rpx;
  transition: opacity 0.5s;
}

.loading-sub {
  display: block;
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
}

/* ── 错误态 ── */
.error-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  margin-top: 48rpx;
}

.error-icon {
  font-size: 80rpx;
}

.error-title {
  font-size: var(--font-xl);
  font-weight: 600;
  color: var(--color-text);
}

.error-desc {
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
  margin-bottom: 16rpx;
}

.btn-retry {
  width: 400rpx;
  height: 88rpx;
  background: var(--color-primary);
  color: #fff;
  border-radius: var(--radius-full);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-md);
  font-weight: 600;
  box-shadow: var(--shadow-btn);
}

.btn-back-home {
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
}
