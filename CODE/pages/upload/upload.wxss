.container {
  min-height: 100vh;
  background: var(--color-bg);
  padding: var(--spacing-lg) var(--spacing-page) 220rpx;
  box-sizing: border-box;
}

/* ── 标题 ── */
.header {
  margin-bottom: 40rpx;
}

.title {
  display: block;
  font-size: var(--font-2xl);
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 12rpx;
}

.subtitle {
  display: block;
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
  line-height: 1.6;
}

/* ── 上传区 ── */
.upload-zone {
  background: var(--color-white);
  border: 3rpx dashed var(--color-border);
  border-radius: var(--radius-lg);
  min-height: 320rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 48rpx 32rpx;
  margin-bottom: 32rpx;
  text-align: center;
  gap: 16rpx;
}

.upload-zone:active {
  background: var(--color-primary-ultra-light);
  border-color: var(--color-primary);
}

.upload-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 8rpx;
}

.upload-main {
  display: block;
  font-size: var(--font-lg);
  font-weight: 600;
  color: var(--color-primary);
  margin-bottom: 8rpx;
}

.upload-hint {
  display: block;
  font-size: var(--font-xs);
  color: var(--color-text-placeholder);
  line-height: 1.7;
  white-space: pre-line;
}

/* ── 文件预览 ── */
.file-preview {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.image-preview-wrap {
  width: 100%;
  max-height: 400rpx;
  border-radius: var(--radius-md);
  overflow: hidden;
}

.preview-image {
  width: 100%;
  max-height: 400rpx;
  border-radius: var(--radius-md);
}

.pdf-preview-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.pdf-icon {
  font-size: 80rpx;
}

.pdf-name {
  font-size: var(--font-sm);
  color: var(--color-text);
  word-break: break-all;
  text-align: center;
}

.file-info {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.file-size {
  font-size: var(--font-xs);
  color: var(--color-text-secondary);
}

.reselect {
  font-size: var(--font-xs);
  color: var(--color-primary);
  text-decoration: underline;
}

/* ── 说明卡片 ── */
.info-card {
  background: var(--color-white);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  box-shadow: var(--shadow-card);
  margin-bottom: 32rpx;
}

.info-title {
  display: block;
  font-size: var(--font-md);
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 20rpx;
}

.info-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.info-item {
  display: block;
  font-size: var(--font-xs);
  color: var(--color-text-secondary);
  line-height: 1.6;
}

/* ── 底部 ── */
.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--color-white);
  padding: 24rpx var(--spacing-page) calc(24rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -2rpx 16rpx rgba(0,0,0,0.06);
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.btn-submit {
  height: 88rpx;
  background: var(--color-primary);
  color: var(--color-white);
  border-radius: var(--radius-full);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-md);
  font-weight: 600;
  box-shadow: var(--shadow-btn);
}

.btn-submit:active { opacity: 0.85; }

.btn-switch {
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
}

.btn-disabled {
  opacity: 0.35;
  pointer-events: none;
}

.disclaimer {
  margin-top: 24rpx;
  font-size: var(--font-xs);
  color: var(--color-text-placeholder);
  text-align: center;
}
