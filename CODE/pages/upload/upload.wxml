<view class="container">
  <!-- 标题 -->
  <view class="header">
    <text class="title">上传肠道体检报告</text>
    <text class="subtitle">AI 智能解析报告内容，为您精准匹配益生菌配方</text>
  </view>

  <!-- 上传区 -->
  <view class="upload-zone" bindtap="onChooseFile">
    <view wx:if="{{!file}}">
      <text class="upload-icon">📁</text>
      <text class="upload-main">点击上传报告</text>
      <text class="upload-hint">支持 JPG / PNG / PDF\n图片 ≤ 5MB · PDF ≤ 2MB</text>
    </view>
    <view wx:else class="file-preview">
      <view wx:if="{{fileType === 'image'}}" class="image-preview-wrap">
        <image class="preview-image" src="{{file.path}}" mode="aspectFit"></image>
      </view>
      <view wx:else class="pdf-preview-wrap">
        <text class="pdf-icon">📄</text>
        <text class="pdf-name">{{file.name}}</text>
      </view>
      <view class="file-info">
        <text class="file-size">{{fileSizeText}}</text>
        <text class="reselect" bindtap="onReselect" catchtap="onCatchTap">重新选择</text>
      </view>
    </view>
  </view>

  <!-- 格式说明 -->
  <view class="info-card">
    <text class="info-title">📋 上传说明</text>
    <view class="info-list">
      <text class="info-item">• 建议上传肠道菌群检测报告或消化系统体检报告</text>
      <text class="info-item">• AI 仅提取菌群、代谢等健康指标，不读取个人身份信息</text>
      <text class="info-item">• 报告内容仅用于本次推荐，不存储至服务器</text>
    </view>
  </view>

  <!-- 提交按钮 -->
  <view class="footer">
    <view
      class="btn-submit {{!file ? 'btn-disabled' : ''}}"
      bindtap="onSubmit"
    >
      <text>生成我的专属推荐</text>
    </view>
    <view class="btn-switch" bindtap="goToSurvey">
      <text>改为填写问卷</text>
    </view>
  </view>

  <!-- 免责 -->
  <view class="disclaimer">
    <text>本内容仅供健康参考，不作为医疗诊断依据</text>
  </view>
</view>
