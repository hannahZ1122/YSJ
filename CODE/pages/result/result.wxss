.container {
  min-height: 100vh;
  background: transparent;
  padding: var(--spacing-lg) var(--spacing-page) 40rpx;
  box-sizing: border-box;
}

/* ── 页面背景图 ── */
.page-bg {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  opacity: 0.13;
  pointer-events: none;
}

/* ── 顶部标题 ── */
.result-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 28rpx;
  text-align: center;
}

.result-label {
  display: block;
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
  margin-bottom: 16rpx;
}

.tag-chip {
  background: var(--color-primary);
  padding: 10rpx 32rpx;
  border-radius: var(--radius-full);
}

.tag-text {
  font-size: var(--font-sm);
  color: #fff;
  font-weight: 600;
}

/* ── 通用卡片 ── */
.card {
  background: var(--color-white);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
  padding: 36rpx 32rpx;
  margin-bottom: 20rpx;
}

.section {}

.section-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.section-icon {
  font-size: 32rpx;
}

.section-title {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--color-text);
}

/* ── 产品主卡 ── */
.product-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: 48rpx 32rpx 36rpx;
}

.product-icon-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: var(--radius-lg);
  background: var(--color-primary-light);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
}

.product-icon { font-size: 60rpx; }

.product-name {
  display: block;
  font-size: var(--font-2xl);
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 12rpx;
}

.product-desc {
  display: block;
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
  line-height: 1.7;
  margin-bottom: 24rpx;
}

/* 功效亮点标签 */
.highlight-row {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 12rpx;
}

.highlight-tag {
  background: var(--color-primary-light);
  border-radius: var(--radius-full);
  padding: 8rpx 24rpx;
  font-size: var(--font-xs);
  color: var(--color-primary-dark);
  font-weight: 600;
}

/* ── 推荐匹配理由 ── */
.match-card {
  border-left: 6rpx solid var(--color-primary);
}

.match-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.match-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.match-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--color-primary);
  flex-shrink: 0;
  margin-top: 10rpx;
}

.match-text {
  font-size: var(--font-sm);
  color: var(--color-text);
  line-height: 1.7;
  flex: 1;
}

/* ── AI 解读 ── */
.ai-section {
  border: 2rpx solid var(--color-primary-light);
}

.ai-icon-emoji { font-size: 30rpx; }

.ai-label {
  font-size: var(--font-md);
  font-weight: 600;
  color: var(--color-primary);
}

.ai-text {
  display: block;
  font-size: var(--font-sm);
  color: var(--color-text);
  line-height: 1.9;
}

/* ── 适合人群 ── */
.target-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.target-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.target-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: var(--color-primary);
  flex-shrink: 0;
  margin-top: 10rpx;
}

.target-text {
  font-size: var(--font-sm);
  color: var(--color-text);
  line-height: 1.6;
  flex: 1;
}

/* ── 核心菌株 ── */
.strains-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.strain-tag {
  background: var(--color-primary-light);
  border-radius: var(--radius-sm);
  padding: 10rpx 20rpx;
}

.strain-text {
  font-size: var(--font-xs);
  color: var(--color-primary-dark);
  font-weight: 500;
}

/* ── 服用建议 ── */
.usage-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.usage-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: var(--color-bg);
  border-radius: var(--radius-md);
  padding: 20rpx 24rpx;
}

.usage-icon { font-size: 36rpx; flex-shrink: 0; }

.usage-content {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.usage-label {
  font-size: var(--font-xs);
  color: var(--color-text-secondary);
}

.usage-value {
  font-size: var(--font-sm);
  color: var(--color-text);
  font-weight: 500;
}

/* ── 配合建议 ── */
.tips-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.tip-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.tip-icon { font-size: 32rpx; flex-shrink: 0; }

.tip-text {
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
  line-height: 1.6;
  flex: 1;
}

/* ── 底部按钮 ── */
.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--color-white);
  padding: 20rpx var(--spacing-page) calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -2rpx 16rpx rgba(0,0,0,0.06);
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.btn-product {
  height: 96rpx;
  background: var(--color-primary);
  border-radius: var(--radius-full);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-btn);
}

.btn-product:active { opacity: 0.85; }

.btn-product-text {
  font-size: var(--font-lg);
  font-weight: 600;
  color: #fff;
}

.btn-restart {
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
}

/* ── 雷达图 ── */
.radar-card {
  padding: 32rpx 32rpx 24rpx;
}

.radar-canvas {
  width: 100%;
  height: 560rpx;
  display: block;
}

/* ── CFU 角标 ── */
.cfu-badge {
  margin-top: 16rpx;
  background: var(--color-bg);
  border-radius: var(--radius-full);
  padding: 8rpx 24rpx;
}

.cfu-text {
  font-size: var(--font-xs);
  color: var(--color-text-secondary);
}

/* ── 配方成分卡 ── */
.ingredient-group {
  margin-bottom: 20rpx;
}

.ingredient-group:last-child { margin-bottom: 0; }

.ingredient-group-label {
  display: block;
  font-size: var(--font-xs);
  color: var(--color-text-secondary);
  margin-bottom: 12rpx;
  font-weight: 600;
}

.prebiotics-tag {
  background: #FFF3E0;
}

.prebiotics-tag .strain-text {
  color: #E65100;
}

.addons-tag {
  background: #E8EAF6;
}

.addons-tag .strain-text {
  color: #3949AB;
}

/* ── 免责声明 ── */
.disclaimer {
  font-size: var(--font-xs);
  color: var(--color-text-placeholder);
  text-align: center;
  line-height: 1.8;
  white-space: pre-line;
  padding: 16rpx 0 32rpx;
}
