.container {
  min-height: 100vh;
  background: transparent;
  padding: 0 var(--spacing-page) var(--spacing-xl);
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

/* ── 页面背景图（fixed，不干扰点击）── */
.page-bg {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  opacity: 0.18;
  pointer-events: none;
}

/* ── 顶部品牌区 ── */
.hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0 60rpx;
}

.logo-placeholder {
  width: 120rpx;
  height: 120rpx;
  border-radius: 30rpx;
  background: var(--color-primary-light);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.logo-icon {
  font-size: 60rpx;
}

.hero-title {
  font-size: var(--font-2xl);
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 16rpx;
  letter-spacing: 2rpx;
}

.hero-subtitle {
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
  text-align: center;
  line-height: 1.7;
  white-space: pre-line;
}

/* ── 入口卡片 ── */
.entry-section {
  margin-top: 8rpx;
}

.entry-card {
  background: var(--color-white);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
  padding: 36rpx 32rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 24rpx;
  transition: all 0.15s;
}

.entry-card:active {
  transform: scale(0.98);
  box-shadow: none;
}

.entry-icon-wrap {
  width: 96rpx;
  height: 96rpx;
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.entry-icon-green {
  background: var(--color-primary-light);
}

.entry-icon-teal {
  background: #E6F4F1;
}

.entry-icon {
  font-size: 44rpx;
}

.entry-content {
  flex: 1;
  min-width: 0;
}

.entry-title {
  display: block;
  font-size: var(--font-lg);
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 8rpx;
}

.entry-desc {
  display: block;
  font-size: var(--font-xs);
  color: var(--color-text-secondary);
  line-height: 1.6;
  white-space: pre-line;
}

.entry-arrow {
  flex-shrink: 0;
}

.arrow-text {
  font-size: 48rpx;
  color: var(--color-border);
  font-weight: 300;
  line-height: 1;
}


/* ── 功能亮点（纯说明，不可点击，刻意弱化） ── */
.features {
  display: flex;
  justify-content: space-around;
  margin-top: 40rpx;
  padding: 24rpx var(--spacing-md);
}

.feature-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.feature-icon {
  font-size: 36rpx;
  opacity: 0.55;
}

.feature-text {
  font-size: var(--font-xs);
  color: var(--color-text-placeholder);
}

/* ── 免责声明 ── */
.disclaimer {
  margin-top: 48rpx;
  font-size: var(--font-xs);
  color: var(--color-text-placeholder);
  text-align: center;
  line-height: 1.8;
  white-space: pre-line;
}
